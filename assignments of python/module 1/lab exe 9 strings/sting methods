# String functions in Python    
'''for finding the lenth of string
we use len(var_name) function '''

'''so basically this function will retun  the integer value for the lenth of string and it will count the nu7mber of characters that are present in that perticular string and it will also count the space as a character'''

h='Hello MUZAMMIL'
print(h)
print(len(h))  
  #---------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
'''and if you want to remove the whitespace from the string then you can use strip() function and it will remove the whitespace from the string and it will return the string without whitespace'''
print(h)
print(h.strip())

#------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------

''' and if oyu want all the text in lower case then you can use lower() function and it will return the string in lower case'''
print(h)
print(h.lower())
#------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
''' and if you want all the text in upper case then you can use upper() function and it will return the string in upper case'''
print(h)
print(h.upper())

#------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
''' and if you want to replace a word in the string then you can use replace() function and it will return the string with the replaced word'''
print(h)
print(h.replace('MUZAMMIL','WORLD'))
'''so basically you put the word or character that you want to replace in the first argument and then you put the word or character that you want to replace with in the second argument and it will return the string with the replaced word or character'''

#------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
'''and if you want to find a word in the string then you can use find() function and it will return the index of the first occurrence of the word in the string and if the word is not found then it will return -1'''
print(h)
print(h.find('MUZAMMIL'))
print(h.find('WORLD'))  #since world is not present in the string it will return -1


#------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
'''and if you want to split the string into a list of words then you can use split() function and it will return a list of words in the string'''
print(h)
print(h.split())  #by default it will split the string by space and it will return a list of words in the string and if you want to split the string by a specific character then you can pass that character as an argument to the split() function and it will split the string by that character and it will return a list of words in the string that are separated by that character'''
print(h)
print(h.split('o'))  #so here we are splitting the string by the character 'o' and it will return a list of words in the string that are separated by the character 'o' and it will also include the character 'o' in the list as well'''


#------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
'''now for the concatination of string we can use + operator and it will concatenate the two strings and it will return a new string that is the concatenation of the two strings'''
s1='Hello'
s2='World'
print(s1)
print(s2)
print(s1+s2)  #so here we are concatenating the two strings s1 and s2 and it will return a new string that is the concatenation of the two strings s1 and s2 and it will not include any space between the two strings so if you want to include a space between the two strings then you can add a space in between the two strings like this s1+' '+s2 and it will return a new string that is the concatenation of the two strings s1 and s2 with a space in between them'''
print(s1+' '+s2)
#------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
'''for the formate string we can use f-string and it will return a new string that is the formate of the string that we have passed as an argument to the f-string and it will also include the value of the variable that we have passed as an argument to the f-string in the formate string'''
name='Muzammil'
age=20
print(f'My name is {name} and my age is {age}')  #so here we are using f-string to formate the string and we are passing the variables name and age as an argument to the f-string and it will return a new string that is the formate of the string that we have passed as an argument to the f-string and it will also include the value of the variable name and age in the formate string'''
#------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
'''and the capitalize() function is used to capitalize the first letter of the string and it will return a new string that is the capitalized version of the original string'''
s='hello world'
print(s)
print(s.capitalize())  #so here we are using the capitalize() function to capitalize the first letter of the string and it will return a new string that is the capitalized version of the original string and it will only capitalize the first letter of the string and it will not capitalize any other letter in the string'''
#------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
'''and the title() function is used to capitalize the first letter of each word in the string and it will return a new string that is the title version of the original string'''
s='hello world'
print(s)
print(s.title())  #so here we are using the title() function to capitalize the first letter of each word in the string and it will return a new string that is the title version of the original string and it will capitalize the first letter of each word in the string and it will not capitalize any other letter in the string'''
#------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
'''and the count() function is used to count the number of occurrences of a word in the string and it will return the number of occurrences of the word in the string'''
s='hello world'
print(s)
print(s.count('o'))  #so here we are using the count() function to count the number of occurrences of the character 'o' in the string and it will return the number of occurrences of the character 'o' in the string and it will also include the character 'o' in the count as well'''
#------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
'''casefold() function is used to convert the string to lower case and it will return a new string that is the lower case version of the original string and it will also include the special characters in the string as well'''
s='HELLO WORLD'
print(s)
print(s.casefold())  #so here we are using the casefold() function to convert the string to lower case and it will return a new string that is the lower case version of the original string and it will also include the special characters in the string as well'''
#------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
'''endswith() function is used to check if the string ends with a specific character or word and it will return True if the string ends with the specific character or word and it will return False if the string does not end with the specific character or word'''
s='hello world'
print(s)
print(s.endswith('d'))  #so here we are using the endswith() function to check if the string ends with the character 'd' and it will return True if the string ends with the character 'd' and it will return False if the string does not end with the character 'd'''
print(s.endswith('o'))  #so here we are using the endswith() function to check if the string ends with the character 'o' and it will return True if the string ends with the character 'o' and it will return False if the string does not end with the character 'o'''
#------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
'''and startswith() function is used to check if the string starts with a specific character or word and it will return True if the string starts with the specific character or word and it will return False if the string does not start with the specific character or word'''
s='hello world'
print(s)
print(s.startswith('h'))  #so here we are using the startswith() function to check if the string starts with the character 'h' and it will return True if the string starts with the character 'h' and it will return False if the string does not start with the character 'h'''
print(s.startswith('w'))  #so here we are using the startswith() function to check if the string starts with the character 'w' and it will return True if the string starts with the character 'w' and it will return False if the string does not start with the character 'w'''
#------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
'''isalnum() function is used to check if the string is alphanumeric and it will return True if the string is alphanumeric and it will return False if the string is not alphanumeric and it will also include the special characters in the string as well'''
s='hello world'
print(s)
print(s.isalnum())  #so here we are using the isalnum() function to check if the string is alphanumeric and it will return True if the string is alphanumeric and it will return False if the string is not alphanumeric and it will also include the special characters in the string as well'''
#------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
'''isalpha() function is used to check if the string is alphabetic and it will return True if the string is alphabetic and it will return False if the string is not alphabetic and it will also include the special characters in the string as well'''
s='hello world'
print(s)
print(s.isalpha())  #so here we are using the isalpha() function to check if the string is alphabetic and it will return True if the string is alphabetic and it will return False if the string is not alphabetic and it will also include the special characters in the string as well'''
#------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------

'''and isdigit() function is used to check if the string is a digit and it will return True if the string is a digit and it will return False if the string is not a digit and it will also include the special characters in the string as well'''
s='12345'
print(s)
print(s.isdigit())  #so here we are using the isdigit() function to check if the string is a digit and it will return True if the string is a digit and it will return False if the string is not a digit and it will also include the special characters in the string as well'''
